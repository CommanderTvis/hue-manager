# Hue Manager Configuration

# Authentication password for the web UI
PASSWORD=your_secure_password_here

# Geographic location for sunrise/sunset calculation
# Format: latitude,longitude (e.g., 55.7558,37.6173 for Moscow)
REGION=55.7558,37.6173

# Pseudo-sunset time (when lamps start transitioning to orange/dim)
# Format: HH:MM (24-hour)
PSEUDO_SUNSET=21:05

# Philips Hue Bridge configuration
# Leave empty for auto-discovery, or set manually
HUE_BRIDGE_IP=

# Hue API username (will be populated automatically after bridge linking)
HUE_USERNAME=
