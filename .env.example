# Hue Manager Configuration

# Authentication password for the web UI and MCP clients
# On first startup, PASSWORD will be hashed and stored in PASSWORD_HASH,
# then PASSWORD will be cleared for security.
PASSWORD=your_secure_password_here
PASSWORD_HASH=

# HMAC secret for signing SPA session tokens (JWT). Must be at least 32 bytes.
# Generate with: openssl rand -base64 48
HUE_JWT_SECRET=
# Optional: session token lifetime in days (default 30).
# HUE_JWT_TTL_DAYS=30

# Geographic location for sunrise/sunset calculation
# Format: latitude,longitude (e.g., 55.7558,37.6173 for Moscow)
REGION=55.7558,37.6173

# Pseudo-sunset time (when lamps start transitioning to orange/dim)
# Format: HH:MM (24-hour)
PSEUDO_SUNSET=21:05

# Time Zone (e.g., Europe/Berlin)
TIMEZONE=Europe/Berlin

# Path to the SQLite database that persists runtime settings (on/off state, schedule
# preferences) across restarts. Defaults to data/hue.db (relative to the working dir).
# In Docker this is overridden to /app/data/hue.db, backed by the hue-data volume.
DATABASE_PATH=data/hue.db

# HTTPS Configuration (Optional)
# If keystore.jks is present in the root directory, it will be used for HTTPS.
# Password for the keystore:
KEYSTORE_PASSWORD=changeit

# Philips Hue Remote API (OAuth2)
# Register at https://developers.meethue.com/add-new-hue-remote-api-app/ to get these credentials
# This allows controlling lamps from anywhere without port forwarding
#
# IMPORTANT: OAuth2 requires HTTPS and a valid domain name
# - HUE_REDIRECT_URI must be HTTPS (e.g., https://yourdomain.com/api/hue/callback)
# - Cannot use HTTP-only URLs or IP addresses in production
# - Set up Caddy or similar reverse proxy for automatic HTTPS (see Caddyfile.example)
HUE_CLIENT_ID=
HUE_CLIENT_SECRET=
HUE_APP_ID=
HUE_REDIRECT_URI=https://yourdomain.com/api/hue/callback

# OAuth2 tokens (populated automatically after authorization)
HUE_ACCESS_TOKEN=
HUE_REFRESH_TOKEN=

# Hue API username (populated automatically after bridge linking)
HUE_USERNAME=

# OAuth (MCP authorization) via Ory Hydra
# ---------------------------------------
# Hydra is the OAuth2 Authorization Server for MCP clients. The Quarkus app validates Hydra's
# JWT access tokens (resource server) and delegates login/consent to its own password screen.
#
# Public issuer URL of Hydra as seen by browsers / MCP clients. For production set this to your
# HTTPS domain (e.g. https://yourdomain.com behind Caddy proxying /oauth2 + /.well-known to Hydra).
HYDRA_ISSUER_URL=http://localhost:4444
#
# Public base URL of THIS app (where Hydra redirects for login/consent). In production this is your
# HTTPS domain (e.g. https://yourdomain.com).
APP_PUBLIC_URL=http://localhost:8080
#
# Hydra system secret for cookie/token encryption. REQUIRED. Generate a random 32+ char string:
#   openssl rand -hex 32
HYDRA_SECRETS_SYSTEM=
